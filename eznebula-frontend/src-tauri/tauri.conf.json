{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EZNebula",
  "version": "1.0.0",
  "identifier": "cn.jayczee.eznebula",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EZNebula",
        "label": "main",
        "width": 380,
        "height": 280,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main window capabilities",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:allow-create",
            "core:webview:allow-create-webview-window",
            "core:webview:allow-webview-position",
            "core:webview:allow-webview-size"
          ]
        },
        {
          "identifier": "sub-window-capability",
          "description": "Sub-windows capabilities",
          "windows": ["sub_*"],
          "permissions": [
            "core:default",
            "core:window:default",
            "core:webview:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/nebula.exe",
      "binaries/wintun.dll"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser"
      }
    }
  }
}
