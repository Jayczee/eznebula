{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EZNebula",
  "version": "1.0.0",
  "identifier": "cn.jayczee.eznebula",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EZNebula",
        "width": 380,
        "height": 280,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "visible": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
